COMPOSE_PROJECT_NAME=rayk-a1
# 基础镜像可按需改为企业或国内代理地址；默认保持官方镜像名
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:7.4-alpine
MINIO_IMAGE=minio/minio:RELEASE.2025-04-22T22-12-26Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-04-16T18-13-26Z
NGINX_IMAGE=nginx:1.27-alpine
MAVEN_IMAGE=docker.m.daocloud.io/library/maven:3.9.9-eclipse-temurin-21
JAVA_RUNTIME_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:21-jre-alpine
MYSQL_DATABASE=rayk_health
MYSQL_USER=rayk
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_password
REDIS_PASSWORD=change_redis_password
MINIO_ROOT_USER=rayk_minio
MINIO_ROOT_PASSWORD=change_minio_password
MINIO_BUCKET_REPORTS=rayk-reports
JWT_SECRET=change_to_a_long_random_secret_at_least_32_bytes
JWT_EXPIRE_SECONDS=7200
SPRING_PROFILES_ACTIVE=docker
RAYK_AI_BASE_URL=http://rayk-ai:8000
RAYK_AI_READ_TIMEOUT_SECONDS=300
RAYK_OCR_MODE=paddle
PADDLE_PDX_MODEL_SOURCE=BOS
# DeepSeek is optional. Keep the key empty in version-controlled files.
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_MAX_TOKENS=2000
DEEPSEEK_THINKING_ENABLED=false
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MINIO_REGION=us-east-1
MINIO_PRESIGN_EXPIRY_SECONDS=600
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
WECHAT_MOCK_ENABLED=true
WECHAT_MOCK_OPENID=rayk-dev-openid
# 仅用于显式模拟首次绑定；正常开发和生产均应保持为空。
WECHAT_AUTO_BIND_USERNAME=
RAYK_DEVELOPMENT_LOGIN_ENABLED=false
JAVA_PORT=8080
AI_PORT=8000
NGINX_PORT=8088
MYSQL_PORT=3307
REDIS_PORT=6380
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
RAYK_BACKUP_DIR=E:\\DockerData\\RayKA1\\backups\\mysql
